#!/usr/bin/env rc

# -- node --

# focus
super + {Left,Right,Up,Down}
	bspc node -f {west,east,north,south}

# swap
super + shift + {Left,Right,Up,Down}
	bspc node -s {west,east,north,south}

# resize
super + alt + {Left,Right,Up,Down}
	resize {left,right,up,down}

# float move
alt + {Left,Right,Up,Down}
	bspc node -v {-20 0,20 0,0 -20,0 20}

# focus last
alt + Tab
	bspc node -f last.local

# swap last / biggest
super + s
	bspc node -s last

super + m
	bspc node -s biggest.local

# state
super + d
	bspc node -t ~floating

super + f
	bspc node -t ~fullscreen

super + t
	bspc node -t ~tiled

super + minus
	bspc node --flag hidden=on

super + q
	bspc node -{c,k}

# -- desktop --

# focus
super + {_,shift +} {1-9}
	bspc {desktop -f,node -d} ^{1-9}

# nav
ctrl + alt + {Left,Right}
	bspc desktop -f {prev,next}.local

ctrl + Tab
	bspc desktop -f last

# rotate
super + space
	bspc node @parent -R 90

# layout
super + o
	bspc desktop -l next

# -- wm --

super + r
	bspc wm -r

super + shift + q
	(pkill -f bar & pkill -f sxhkd & bspc quit)

# -- apps --

super + e
	9 spawn st fm

super + p
	dmenu_run

super + Return
	spawn st

super + w
	wp

super + z
	switch

# -- misc --

F11
	bspc node -t ~fullscreen
