#!/usr/bin/env bash

SESSIONS=~/.claude/projects

# -------------------------------------------------------
# Helpers
# -------------------------------------------------------

nth()
{
    local j=0
    for f in "$SESSIONS"/*/*.jsonl; do
        ((++j == $1)) && echo "$f" && return
    done
}

projdir()
{
    jq -r 'select(.cwd) | .cwd' "$1" 2>/dev/null | head -1
}

sid()
{
    basename "$1" .jsonl
}

title()
{
    jq -r 'select(.type=="custom-title") | .customTitle' \
        "$1" 2>/dev/null | tail -1
}

# -------------------------------------------------------
# Actions
# -------------------------------------------------------

list()
{
    local i=0 f proj size time
    for f in "$SESSIONS"/*/*.jsonl; do
        proj=$(basename "$(projdir "$f")")
        size=$(du -h "$f" | cut -f1)
        time=$(find "$f" -printf '%Tm-%Td %TH:%TM\n')
        printf "%2d) %-20s %-15s %5s  %s\n" \
            "$((++i))" "$(title "$f")" \
            "$proj" "$size" "$time"
    done
}

delete()
{
    local f
    f=$(nth "$1") || return
    rm -f "$f" && rm -rf "${f%.jsonl}"
}

fork()
{
    local f name
    f=$(nth "$1") || return
    read -rp "Name: " name
    cd "$(projdir "$f")" &&
    claude --resume "$(sid "$f")" --fork-session --name "$name"
}

resume()
{
    local f
    f=$(nth "$1") || return
    cd "$(projdir "$f")" && claude --resume "$(sid "$f")"
}

# -------------------------------------------------------
# Menu
# -------------------------------------------------------

menu()
{
    local sel n
    while true; do
        clear
        list
        echo
        echo "[r]esume  [d]elete  [f]ork  [q]uit"
        echo
        read -rp "❯ " sel
        [[ -z $sel ]] && continue
        [[ $sel == q ]] && break
        n=${sel:1}
        case ${sel:0:1} in
            r) resume "$n"; break ;;
            f) fork "$n"; break ;;
            d) delete "$n" ;;
        esac
    done
}

menu
