#!/usr/bin/env bash

SESSIONS=~/.claude/projects

# -------------------------------------------------------
# Helpers
# -------------------------------------------------------

nth()
{
    local f j=0
    for f in "$SESSIONS"/*/*.jsonl; do
        ((++j == $1)) && echo "$f" && return
    done
}

fields()  # stdout: cwd<TAB>title
{
    local cwd title
    cwd=$(rg -om1 '"cwd":"([^"]*)"' -r '$1' "$1" 2>/dev/null)
    title=$(rg -o '"customTitle":"([^"]*)"' -r '$1' "$1" 2>/dev/null | tail -1)
    printf '%s\t%s' "$cwd" "$title"
}

sid()
{
    basename "$1" .jsonl
}

# -------------------------------------------------------
# Actions
# -------------------------------------------------------

statmap()  # populates size and mtime by path
{
    local bytes epoch f
    while IFS=$'\t' read -r f bytes epoch; do
        size[$f]=$(( (bytes + 512) / 1024 ))K
        printf -v mtime[$f] '%(%m-%d %H:%M)T' "$epoch"
    done < <(stat -c $'%n\t%s\t%Y' "$SESSIONS"/*/*.jsonl 2>/dev/null)
}

list()
{
    local -A size mtime
    local cwd f i=0 proj title
    statmap

    for f in "$SESSIONS"/*/*.jsonl; do
        IFS=$'\t' read -r cwd title < <(fields "$f")
        proj=$(basename "$cwd")
        printf "%d) %-16s %-16s %-5s %s\n" \
            "$((++i))" "$title" "$proj" "${size[$f]}" "${mtime[$f]}"
    done
}

delete()
{
    local f
    f=$(nth "$1") || return
    rm -f "$f" && rm -rf "${f%.jsonl}"
}

fork()
(
    local cwd f name title
    f=$(nth "$1") || return
    IFS=$'\t' read -r cwd title < <(fields "$f")
    read -erp "name: " -i "scratch" name
    cd "$cwd" && claude --resume "$(sid "$f")" --fork-session --name "$name"
)

add()
(
    local dir name
    read -erp "dir: " -i "$HOME/scratch" dir
    [[ -z $dir ]] && return
    dir=$(eval echo "$dir")
    [[ -d $dir ]] || return
    read -erp "name: " -i "scratch" name
    [[ -z $name ]] && return
    cd "$dir" && claude --name "$name"
)

resume()
(
    local cwd f title
    f=$(nth "$1") || return
    IFS=$'\t' read -r cwd title < <(fields "$f")
    cd "$cwd" && claude --resume "$(sid "$f")"
)

# -------------------------------------------------------
# Menu
# -------------------------------------------------------

menu()
{
    local n sel
    while true; do
        clear
        list
        echo
        echo "[a]dd  [r]esume  [d]elete  [f]ork  [q]uit"
        echo
        read -rp "❯ " sel
        [[ -z $sel ]] && continue
        [[ $sel == q ]] && break
        if [[ $sel =~ ^[0-9]+$ ]]; then
            resume "$sel"; break
        fi
        n=${sel:1}
        case ${sel:0:1} in
            a) add; break ;;
            r) resume "$n"; break ;;
            f) fork "$n"; break ;;
            d) delete "$n" ;;
        esac
    done
}

menu
